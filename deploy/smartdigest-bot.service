[Unit]
Description=SmartDigest Telegram Bot
After=network.target

[Service]
Type=simple
User=smartdigest
Group=smartdigest
WorkingDirectory=/home/smartdigest/smartdigest-tgbot
EnvironmentFile=/home/smartdigest/smartdigest-tgbot/.env
ExecStart=/home/smartdigest/smartdigest-tgbot/.venv/bin/python -m smartdigest_bot
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
